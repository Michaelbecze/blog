---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  hasMermaid?: boolean;
}

const {
  title,
  description = 'A technical blog on routing decisions, packet flow, and how data moves through real networks.',
  hasMermaid = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteTitle = 'The Forwarding Table';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === siteTitle ? title : `${title} | ${siteTitle}`}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    {hasMermaid && (
      <script type="module">
        import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
        mermaid.initialize({ startOnLoad: true, theme: 'dark' });
      </script>
    )}
  </head>
  <body>
    <header class="site-nav">
      <div class="nav-inner">
        <a href={base} class="nav-brand">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
          The Forwarding Table
        </a>
        <nav class="nav-links">
          <a href={base}>Posts</a>
          <a href={`${base}about/`}>About</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} The Forwarding Table · Built with <a href="https://astro.build" style="color: inherit; text-decoration: underline;">Astro</a></p>
    </footer>
  </body>
</html>
